---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import CodeCopy from "../components/CodeCopy.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const { title, description, pagefind} = Astro.props;
---

<html lang="zh-CN" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="utf-8" />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <title>{title ?? "未命名"}</title>
    <script is:inline>
      // oxlint-disable-next-line typescript/explicit-function-return-type
      (() => {
        const theme = localStorage.getItem("theme") || "light";
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <meta content="width=device-width,initial-scale=1" name="viewport" />
    <meta content={title ?? "未命名"} property="og:title" />
    <meta content="article" property="og:type" />
    {description ? (<meta content={String(description)} property="og:description" />) : null}
    <meta content="zh_CN" property="og:locale" />
    <meta content="未命名" property="og:site_name" />
    <meta content="Li Hua" property="og:article:author:first_name" />
    <meta content="summary" name="twitter:card" />
    <meta content={Astro.generator} name="generator" />
    <link
      href="https://creativecommons.org/licenses/by-nc-sa/4.0/legalcode.txt"
      rel="license"
    />
    <link href="/sitemap-index.xml" rel="sitemap" />
    <script>
      import "../scripts/theme-toggle";
    </script>
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-component-ui.js" type="module"></script>
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen bg-base-100 text-base-content" {...(pagefind ? {"data-pagefind-body": ""} : {})}>
    <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-primary z-[60] transition-[width] duration-150 ease-out" />
    <Header />
    <main class="flex-grow">
      <CodeCopy />
      <slot />
    </main>
    <Footer />
  </body>
</html>
