---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import CodeCopy from "../components/CodeCopy.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const { title, description, pagefind, publishDate, updatedDate, authors, tags, section, image, url, canonical } = Astro.props;
---

<html lang="zh-CN" prefix="og: https://ogp.me/ns# article: https://ogp.me/ns/article#">
  <head>
    <meta charset="utf-8" />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <title>{title ?? "未命名"}</title>
    <script is:inline>
      // oxlint-disable-next-line typescript/explicit-function-return-type
      (() => {
        const theme = localStorage.getItem("theme") || "light";
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <meta content="width=device-width,initial-scale=1" name="viewport" />
    <meta content={title ?? "未命名"} property="og:title" />
    <meta content="article" property="og:type" />
    {description ? (<meta content={String(description)} property="og:description" />) : null}
    <meta content="zh_CN" property="og:locale" />
    <meta content="未命名" property="og:site_name" />
    {url ? (<meta content={String(url)} property="og:url" />) : null}
    {image ? (<meta content={String(image)} property="og:image" />) : null}
    {publishDate ? (<meta content={String(publishDate)} property="article:published_time" />) : null}
    {updatedDate ? (<meta content={String(updatedDate)} property="article:modified_time" />) : null}
    {section ? (<meta content={String(section)} property="article:section" />) : null}
    {tags ? (Array.isArray(tags) ? tags.map(t => <meta property="article:tag" content={t} />) : <meta property="article:tag" content={String(tags)} />) : null}
    {authors ? (Array.isArray(authors) ? authors.map(a => <meta property="article:author" content={a} />) : <meta property="article:author" content={String(authors)} />) : null}
    <meta content="summary" name="twitter:card" />
    {canonical ? (<link rel="canonical" href={String(canonical)} />) : null}
    <meta content={Astro.generator} name="generator" />
    <link
      href="https://creativecommons.org/licenses/by-nc-sa/4.0/legalcode.txt"
      rel="license"
    />
    <link href="/sitemap-index.xml" rel="sitemap" />
    <script>
      import "../scripts/theme-toggle";
    </script>
    <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-component-ui.js" type="module"></script>
    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-screen bg-base-100 text-base-content" {...(pagefind ? {"data-pagefind-body": ""} : {})}>
    <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-primary z-[60] transition-[width] duration-150 ease-out" />
    <Header />
    <main class="flex-grow">
      <CodeCopy />
      <slot />
    </main>
    <Footer />
  </body>
</html>
