  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm opacity-60">
      <div class="flex items-center gap-3">
        <img src="https://gravatar.com/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=24" alt="" class="w-5 h-5 rounded-full" onerror="this.onerror=null;var i=this;i.src='https://gravatar.loli.net/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=24';i.onerror=function(){i.style.display='none'}" />
