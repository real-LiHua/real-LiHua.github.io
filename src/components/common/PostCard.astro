---
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";
import { formatDate } from "../../utils/date";

interface Props {
  post: CollectionEntry<"blog">["data"] & { id: string };
  variant?: "grid" | "list";
}

const { post, variant = "grid" } = Astro.props;

const formattedDate = formatDate(post.publishDate);
const hasTags = post.tags && post.tags.length > 0;
---

{
  variant === "grid" ? (
    <article class="group">
      <a
        href={`/posts/${post.id}`}
        class="block p-5 rounded-xl border border-base-200 hover:border-pink-500/30 hover:shadow-lg hover:shadow-pink-500/5 transition-all duration-300 h-full flex flex-col"
      >
        <time class="text-xs font-mono opacity-50">{formattedDate}</time>
        <h2 class="text-lg font-medium group-hover:text-pink-500 transition-colors line-clamp-2 mt-2">
          {post.title}
        </h2>
        <p class="text-sm opacity-80 line-clamp-3 flex-grow mt-2">
          {post.description}
        </p>
        {hasTags && (
          <div class="flex flex-wrap gap-1.5 mt-4 pt-3 border-t border-base-200">
            {post.tags!.map((tag) => <Tag tag={tag} />)}
          </div>
        )}
      </a>
    </article>
  ) : (
    <article class="group">
      <a
        href={`/posts/${post.id}`}
        class="block p-6 -mx-2 rounded-2xl hover:bg-base-200/50 transition-all duration-300"
      >
        <div class="flex items-baseline gap-4 mb-2">
          <time class="text-sm font-mono opacity-60 shrink-0">
            {formattedDate}
          </time>
          <h2 class="text-xl font-normal group-hover:text-pink-500 transition-colors">
            {post.title}
          </h2>
        </div>
        <p class="text-sm opacity-80 pl-[4.5rem] line-clamp-2">
          {post.description}
        </p>
      </a>
    </article>
  )
}
