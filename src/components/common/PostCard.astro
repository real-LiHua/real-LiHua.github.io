---
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";
import { formatDate } from "../../utils/date";

interface Props {
  post: CollectionEntry<"blog">["data"] & { id: string };
  variant?: "grid" | "list";
}

const { post, variant = "grid" } = Astro.props;

const formattedDate = formatDate(post.publishDate);
const dateISO = formatDate(post.publishDate, "full");
const hasTags = post.tags && post.tags.length > 0;
---

{
  variant === "grid" ? (
    <article class="group tilt-card">
      <div class="card card-border bg-base-100 border-base-200 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 h-full block">
        <div class="card-body">
          {post.publishDate ? (<time class="text-xs font-mono opacity-40" datetime={dateISO}>{formattedDate}</time>) : null}
          <h2 class="card-title text-lg mt-1">
            <a href={`/posts/${post.id}`} class="group-hover:text-primary transition-colors">{post.title}</a>
          </h2>
          {post.description && <p class="text-sm opacity-70 line-clamp-3">{post.description}</p>}
          {hasTags && (
            <div class="card-actions mt-4 pt-3 border-t border-base-200 flex flex-wrap gap-1.5">
              {post.tags!.map((tag) => <Tag tag={tag} />)}
            </div>
          )}
        </div>
      </div>
    </article>
  ) : (
    <article class="group">
      <div class="flex items-baseline gap-4 p-4 -mx-4 rounded-xl hover:bg-base-200/50 transition-all duration-300">
        {post.publishDate ? (<time class="text-sm font-mono opacity-40 shrink-0 w-20 text-right" datetime={dateISO}>{formattedDate}</time>) : null}
        <div>
          <h2 class="text-lg font-medium">
            <a href={`/posts/${post.id}`} class="group-hover:text-primary transition-colors">{post.title}</a>
          </h2>
          {post.description && <p class="text-sm opacity-60 mt-1 line-clamp-1">{post.description}</p>}
        </div>
      </div>
    </article>
  )
}
