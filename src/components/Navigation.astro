---
import End from "./navbar/End.astro";
---

<div class="navbar max-w-6xl mx-auto px-4">
  <div class="navbar-start">
    <a href="/" class="flex items-center gap-2.5">
      <img src="https://gravatar.com/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=32" alt="" class="w-6 h-6 rounded-full" onerror="this.onerror=null;var i=this;i.src='https://gravatar.loli.net/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=32';i.onerror=function(){i.style.display='none'}" />
      <span class="text-sm font-medium opacity-70">李华的博客</span>
    </a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul class="flex items-center gap-0.5">
      <li><a href="/" class="btn btn-ghost btn-sm rounded-full">首页</a></li>
      <li><a href="/tags" class="btn btn-ghost btn-sm rounded-full">标签</a></li>
      <li><a href="/about" class="btn btn-ghost btn-sm rounded-full">关于</a></li>
      {
        import.meta.env.DEV && (
          <li>
            <a href="/drafts" class="btn btn-ghost btn-sm rounded-full">草稿</a>
          </li>
        )
      }
    </ul>
  </div>
  <div class="navbar-end flex items-center gap-2">
    <div class="lg:hidden dropdown dropdown-end">
      <div class="btn btn-circle btn-ghost btn-sm" role="button" tabindex="0">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </div>
      <ul
        class="dropdown-content menu z-1 mt-3 w-52 rounded-box bg-base-100 border border-base-300 p-2 shadow-lg"
        tabindex="0"
      >
        <li><a href="/">首页</a></li>
        <li><a href="/tags">标签</a></li>
        <li><a href="/about">关于</a></li>
        {
          import.meta.env.DEV && (
            <li><a href="/drafts">草稿</a></li>
          )
        }
      </ul>
    </div>
    <End />
  </div>
</div>
