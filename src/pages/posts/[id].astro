---
export const prerender = false;

---

<script>
  const PADDING = 8;
  const ROOT_MARGIN = "-80px 0px -80% 0px";

  const clamp = (value: number, min: number, max: number): number =>
    Math.max(min, Math.min(value, max));

  const createDragState = (): {
    initialLeft: number;
    initialTop: number;
    isDragging: boolean;
    startX: number;
    startY: number;
  } => ({
    initialLeft: 0,
    initialTop: 0,
    isDragging: false,
    startX: 0,
    startY: 0,
  });

  const initMouseDrag = (
    state: ReturnType<typeof createDragState>,
    toggle: HTMLButtonElement,
  ): {
    onMouseDown: (event: MouseEvent) => void;
    onMouseMove: (event: MouseEvent) => void;
    onMouseUp: () => void;
  } => ({
    onMouseDown: (event: MouseEvent): void => {
      state.isDragging = true;
      state.startX = event.clientX;
      state.startY = event.clientY;
      const rect = toggle.getBoundingClientRect();
      state.initialLeft = rect.left;
      state.initialTop = rect.top;
      toggle.style.transition = "none";
    },
    onMouseMove: (event: MouseEvent): void => {
      if (!state.isDragging) { return; }
      const dx = event.clientX - state.startX;
      const dy = event.clientY - state.startY;
      const rect = toggle.getBoundingClientRect();
      const newLeft = clamp(state.initialLeft + dx, PADDING, window.innerWidth - rect.width - PADDING);
      const newTop = clamp(state.initialTop + dy, PADDING, window.innerHeight - rect.height - PADDING);
      toggle.style.left = `${newLeft}px`;
      toggle.style.top = `${newTop}px`;
      toggle.style.right = "auto";
    },
    onMouseUp: (): void => { state.isDragging = false; },
  });

  const initTouchDrag = (
    _state: ReturnType<typeof createDragState>,
    toggle: HTMLButtonElement,
    handlers: ReturnType<typeof initMouseDrag>,
  ): void => {
    toggle.addEventListener("touchstart", (evt: TouchEvent) => {
      const [touchPoint] = evt.touches;
      handlers.onMouseDown({ clientX: touchPoint.clientX, clientY: touchPoint.clientY } as MouseEvent);
    }, { passive: false });

    toggle.addEventListener("touchmove", (evt: TouchEvent) => {
      evt.preventDefault();
      const [touchPoint] = evt.touches;
      handlers.onMouseMove({ clientX: touchPoint.clientX, clientY: touchPoint.clientY } as MouseEvent);
    }, { passive: false });

    toggle.addEventListener("touchend", handlers.onMouseUp);
  };

  const setupDragListeners = (toggle: HTMLButtonElement): void => {
    const state = createDragState();
    const handlers = initMouseDrag(state, toggle);
    toggle.addEventListener("mousedown", handlers.onMouseDown);
    document.addEventListener("mousemove", handlers.onMouseMove);
    document.addEventListener("mouseup", handlers.onMouseUp);
    initTouchDrag(state, toggle, handlers);
  };

  const setupPanelToggle = (toggle: HTMLButtonElement, panel: HTMLElement): void => {
    toggle.addEventListener("click", () => { panel.classList.toggle("hidden"); });
    document.addEventListener("click", (evt: MouseEvent) => {
      if (!toggle.contains(evt.target as Node) && !panel.contains(evt.target as Node)) {
        panel.classList.add("hidden");
      }
    });
  };

  const setupTocObserver = (tocLinks: NodeListOf<HTMLAnchorElement>): void => {
    const tocHeadings = [...tocLinks]
      .map((link) => {
        const href = link.getAttribute("href");
        if (!href) { return undefined; }
        const id = href.slice(1);
        if (!id) { return undefined; }
        return document.querySelector(`#${id}`);
      })
      .filter((el): el is HTMLElement => el !== undefined);

    if (tocHeadings.length === 0) { return; }

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const { id } = entry.target;
          for (const link of tocLinks) {
            const isActive = link.getAttribute("href") === `#${id}`;
            link.classList.toggle("text-pink-500", isActive);
            link.classList.toggle("opacity-100", isActive);
            link.classList.toggle("opacity-50", !isActive);
          }
        }
      }
    }, { rootMargin: ROOT_MARGIN });

    for (const heading of tocHeadings) {
      observer.observe(heading);
    }
  };

  document.addEventListener("astro:page-load", () => {
    const toggle = document.querySelector<HTMLButtonElement>("#toc-toggle");
    const panel = document.querySelector<HTMLElement>("#toc-panel");

    if (toggle) { setupDragListeners(toggle); }
    if (toggle && panel) { setupPanelToggle(toggle, panel); }

    const tocLinks = document.querySelectorAll("#toc-sidebar a, #toc-panel a") as NodeListOf<HTMLAnchorElement>;
    setupTocObserver(tocLinks);
  });
</script>
