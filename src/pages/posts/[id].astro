---
import type { GetStaticPathsResult } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/common/Tag.astro";
import { formatDate } from "../../utils/date";
import { render } from "astro:content";
import { getPublishedPosts, getAllPosts } from "../../utils/content";

export const prerender = true;

export const getStaticPaths = async (): Promise<GetStaticPathsResult> => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { id: post.id },
  }));
};

const { id } = Astro.params;
const isDev = import.meta.env.DEV;
const posts = isDev ? await getAllPosts() : await getPublishedPosts();
const post = posts.find((entry) => entry.id === id);

if (!post) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(post);

const { title, description, publishDate, tags: rawTags, updatedDate, authors: fmAuthors, image: fmImage } = post.data;
const tags = rawTags ?? [];
// 自动填充：作者优先使用 frontmatter 的 authors，否则回退到站点所有者
const authors: string[] = (() => {
  if (Array.isArray(fmAuthors)) { return fmAuthors.map(String); }
  if (fmAuthors) { return [String(fmAuthors)]; }
  return ["Li Hua"];
})();
// 图片优先使用 frontmatter 的 image 字段，否则回退到站点 favicon
const image: string = (() => {
  if (fmImage) { return String(fmImage); }
  if (Astro.site) { return `${Astro.site}favicon.svg`; }
  return "/favicon.svg";
})();
// 构建文章的完整 url 与 canonical
const url = Astro.site ? `${Astro.site}posts/${post.id}/` : `/posts/${post.id}/`;
const canonical = url;
const hasTags = tags.length > 0;
// 优先使用插件注入的 toc（post.data.toc），回退到 render 返回的 headings
const tocFromPlugin = (post.data as unknown as { toc?: unknown })?.toc;
const toc = Array.isArray(tocFromPlugin)
  ? (tocFromPlugin as { depth: number; slug: string; text: string }[])
  : headings.map(({ depth, slug, text }) => ({ depth, slug, text }));
const hasToc = toc.length > 0;
---

<BaseLayout {title} {description} pagefind={true} publishDate={publishDate} updatedDate={updatedDate} authors={authors} tags={tags} image={image} url={url} canonical={canonical}>
  <div class="relative max-w-6xl mx-auto px-4 lg:grid lg:grid-cols-[1fr_14rem] lg:gap-12">
    <article class="py-16 sm:py-24 min-w-0">
      <div class="mb-12 reveal">
        {publishDate && (
        <div class="flex items-center gap-3 text-sm font-mono opacity-40 mb-4">
          <time datetime={formatDate(publishDate, "full")}>{formatDate(publishDate)}</time>
        </div>
      )}
        <h1 class="text-3xl sm:text-4xl font-medium tracking-tight text-balance">
          {title}
        </h1>
        {description && (
          <p class="text-lg opacity-60 mt-4 leading-relaxed text-balance">{description}</p>
        )}
        {hasTags && (
          <div class="flex flex-wrap gap-2 mt-6">
            {tags.map((tag) => <Tag tag={tag} />)}
          </div>
        )}
      </div>
      <div class="prose prose-neutral dark:prose-invert max-w-none reveal reveal-delay-1">
        <Content />
      </div>
    </article>

    {hasToc && (
      <aside id="toc-sidebar" class="hidden lg:block pt-24">
        <div class="sticky top-24">
          <h3 class="text-xs font-mono tracking-widest opacity-40 mb-4 uppercase">目录</h3>
          <nav class="space-y-1.5 text-sm">
            {
            toc.map(({ depth, slug, text }) => (
                <a
                  href={`#${slug}`}
                  class="block transition-all duration-200 opacity-50 hover:opacity-100 hover:text-primary"
                  style={`padding-left: ${Math.max(depth - 2, 0) * 0.75}rem`}
                >
                  {text}
                </a>
              ))
            }
          </nav>
        </div>
      </aside>
    )}
  </div>

  {hasToc && (
    <>
      <button
        id="toc-toggle"
        class="btn btn-sm fixed z-40 shadow-lg bg-base-100 border-base-300 lg:hidden px-3 text-base font-medium"
        aria-label="打开目录"
        style="right: 1.5rem; bottom: 1.5rem;"
      >
        目录
      </button>

      <div id="toc-panel" class="hidden lg:hidden fixed z-50 bottom-20 right-4 w-64 max-h-80 overflow-y-auto rounded-box bg-base-100 border border-base-300 shadow-xl p-4">
        <h3 class="text-xs font-mono tracking-widest opacity-40 mb-3 uppercase">目录</h3>
        <nav class="space-y-1.5 text-sm">
          {
            toc.map(({ depth, slug, text }) => (
              <a
                href={`#${slug}`}
                class="block transition-all duration-200 opacity-50 hover:opacity-100 hover:text-primary"
                style={`padding-left: ${Math.max(depth - 2, 0) * 0.75}rem`}
              >
                {text}
              </a>
            ))
          }
        </nav>
      </div>
    </>
  )}
  <script>
    import "../../scripts/toc";
    import "../../scripts/reading-progress";
    import "../../scripts/scroll-reveal";
  </script>
</BaseLayout>
