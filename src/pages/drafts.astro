---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

if (!import.meta.env.DEV) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

dayjs.extend(localizedFormat);

const blogPosts = await getCollection(
  "blog",
  ({ data }) => data.draft === true,
);
const posts: (CollectionEntry<"blog">["data"] & { id: string })[] =
  await Promise.all(
    blogPosts.map(async (post) => {
      const { remarkPluginFrontmatter } = await render(post);
      return { ...remarkPluginFrontmatter, ...post.data, id: post.id };
    }),
  );
posts.sort((a, b) => {
  const A = dayjs(a.publishDate);
  const B = dayjs(b.publishDate);
  if (A.isSame(B)) return 0;
  if (A.isBefore(B)) return 1;
  return -1;
});
---

<BaseLayout title="草稿">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-light text-center mb-12 tracking-wider">草稿</h1>
    {
      posts.length === 0 ? (
        <p class="text-center opacity-60">暂无草稿</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="group">
              <a
                href={`/posts/${post.id}`}
                class="block p-5 rounded-xl border border-base-200 hover:border-pink-500/30 hover:shadow-lg hover:shadow-pink-500/5 transition-all duration-300 h-full flex flex-col"
              >
                <time class="text-xs font-mono opacity-50 mb-2">
                  {dayjs(post.publishDate).format("YYYY.MM.DD")}
                </time>
                <h2 class="text-lg font-medium mb-2 group-hover:text-pink-500 transition-colors line-clamp-2">
                  {post.title}
                </h2>
                <p class="text-sm opacity-60 line-clamp-3 flex-grow">
                  {post.description}
                </p>
                {post.tags && post.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-4 pt-3 border-t border-base-200">
                    {post.tags.map((tag) => (
                      <span class="text-xs text-pink-500">#{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
