---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/common/PostCard.astro";
import { sortByDate } from "../utils/date";
import { type CollectionEntry, render } from "astro:content";
import { getDraftPosts } from "../utils/content";

const devEnv = import.meta.env.DEV;
if (!devEnv) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

const blogPosts = await getDraftPosts();
const posts: (CollectionEntry<"blog">["data"] & { id: string })[] =
  await Promise.all(
    blogPosts.map(async (post) => {
      const { remarkPluginFrontmatter } = await render(post);
      return { ...remarkPluginFrontmatter, ...post.data, id: post.id };
    }),
  );
const sortedPosts = sortByDate(posts);
---

<BaseLayout title="草稿">
  <div class="max-w-6xl mx-auto px-4 py-24">
    <div class="max-w-2xl mx-auto">
      <div class="mb-12 reveal">
        <h1 class="text-3xl font-medium">草稿</h1>
        <p class="text-sm opacity-50 mt-1">Drafts</p>
      </div>
      {
        sortedPosts.length === 0 ? (
          <p class="text-center opacity-60 py-12 reveal reveal-delay-1">暂无草稿</p>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            {sortedPosts.map((post, idx) => (
              <div class:list={["reveal", `reveal-delay-${Math.min(idx + 1, 4)}`]}>
                <PostCard post={post} />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
  <script>
    import "../scripts/scroll-reveal";
    import "../scripts/tilt-card";
  </script>
</BaseLayout>
