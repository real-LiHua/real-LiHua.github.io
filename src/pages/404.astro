---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="未找到">
  <div class="max-w-6xl mx-auto px-4 py-32 text-center" data-pagefind-ignore>
    <h1 class="text-4xl font-medium mb-4 reveal">404</h1>
    <p class="text-lg opacity-50 mb-8 reveal reveal-delay-2">未找到该页面</p>
    <a href="/" class="btn btn-primary reveal reveal-delay-3">返回首页</a>
  </div>
  <script>
    import "../scripts/scroll-reveal";
  </script>
</BaseLayout>
