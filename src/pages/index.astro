---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/common/PostCard.astro";
import { sortByDate } from "../utils/date";
import { type CollectionEntry, render } from "astro:content";
import { getPublishedPosts } from "../utils/content";

const blogPosts = await getPublishedPosts();
const posts: (CollectionEntry<"blog">["data"] & { id: string })[] =
  await Promise.all(
    blogPosts.map(async (post) => {
      const { remarkPluginFrontmatter } = await render(post);
      return { ...remarkPluginFrontmatter, ...post.data, id: post.id };
    }),
  );
const sortedPosts = sortByDate(posts);
const recentPosts = sortedPosts.slice(0, 6);
const hasMore = sortedPosts.length > 6;
---

<BaseLayout title="李华的博客">
  <div class="relative overflow-hidden">

    <div class="relative max-w-6xl mx-auto px-4 py-24 sm:py-32">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-4">
          <img src="https://gravatar.com/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=48" alt="" class="w-8 h-8 rounded-full reveal" data-gravatar-fallback="https://gravatar.loli.net/avatar/9743ba359d77c45acd627d1c02001ed803dbe4f541521cb4dbd30a068f680478?s=48" />
          <span class="text-sm font-mono opacity-40 reveal reveal-delay-1">l i h u a</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-medium tracking-tight text-balance reveal reveal-delay-1">
          李华的博客
        </h1>
        <p class="text-lg opacity-60 mt-4 max-w-lg text-balance leading-relaxed reveal reveal-delay-2">
          一些乱七八糟的想法和踩过的坑。
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 pb-24">
    <div class="flex items-center gap-3 mb-8 reveal">
      <span class="h-px flex-grow bg-base-200"></span>
      <span class="text-xs font-mono tracking-widest opacity-40">LATEST</span>
      <span class="h-px flex-grow bg-base-200"></span>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {recentPosts.map((post, idx) => (
        <div class:list={["reveal", `reveal-delay-${Math.min(idx + 1, 4)}`]}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
    {hasMore && (
      <div class="text-center mt-10 reveal">
        <a href="/posts" class="btn btn-ghost rounded-full px-8">
          查看全部文章
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
  <script>
    import "../scripts/gravatar-fallback";
    import "../scripts/scroll-reveal";
    import "../scripts/tilt-card";
  </script>
</BaseLayout>
