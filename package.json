{
  "name": "blog",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "check:links": "lychee dist/client",
    "build:clean": "rm -f public/pagefind",
    "build:astro": "astro check && astro build",
    "build:pagefind": "pagefind --site dist/client && ln -sf ../dist/client/pagefind public/pagefind",
    "build:vnu": "vnu --skip-non-html dist/client",
    "build": "pnpm run build:clean && pnpm run build:astro && pnpm run build:pagefind && pnpm run check:links && pnpm run build:vnu",
    "preview": "pnpm run build && wrangler dev",
    "astro": "astro",
    "prepare": "husky",
    "post:edit": "cargo run -p post-edit --"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/node": "^11.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.10",
    "@fontsource/twinkle-star": "^5.2.8",
    "@grammyjs/auto-retry": "^2.0.2",
    "@helia/strings": "^5.1.1",
    "@shopify/draggable": "^1.2.1",
    "@swup/astro": "^1.8.0",
    "@swup/overlay-theme": "^2.0.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "animate.css": "^4.1.1",
    "astro": "^7.0.7",
    "daisyui": "^5.6.17",
    "gaxios": "^7.2.0",
    "grammy": "^1.44.0",
    "helia": "^6.1.4",
    "pinata": "^2.5.6",
    "tailwindcss": "^4.3.2",
    "the-answer": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@playwright/mcp": "^0.0.77",
    "@vite-pwa/astro": "^1.2.0",
    "dayjs": "^1.11.21",
    "husky": "^9.1.7",
    "jsonc-parser": "^3.3.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "pagefind": "^1.5.2",
    "playwright": "^1.61.1",
    "unist-util-visit": "^5.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vnu-jar": "^26.7.11",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx}": [
      "oxlint",
      "oxfmt"
    ],
    "*.astro": [
      "oxlint"
    ],
    "*.css": [
      "oxlint",
      "oxfmt"
    ],
    "!(*.css|*.js|*.mjs|*.jsx|*.ts|*.tsx|*.astro|*.rs)": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.3.0"
}
